rules_version = '2';

// ──────────────────────────────────────────────────────────────────────────────
// Ramsha — Firestore Security Rules
// Roles: Admin, Organizer (legacy: Provider), Participant, Judge, Sponsor
// ──────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function getUserRoles() {
      let data = getUserData();
      return data.keys().hasAny(['roles']) ? data.roles : [data.role];
    }

    function hasRole(role) {
      return isSignedIn() && (role in getUserRoles());
    }

    function isOrganizer() {
      return hasRole('Organizer') || hasRole('Provider');
    }

    function isParticipant() {
      return hasRole('Participant');
    }

    function isJudge() {
      return hasRole('Judge');
    }

    function isAdmin() {
      return hasRole('Admin');
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── users collection ──────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isOrganizer() ||
        isAdmin()
      );
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ── events collection (unified for all event types) ──────────────────────
    match /events/{eventId} {
      // Public events readable by anyone authenticated; own events by organizer
      allow read: if isSignedIn() || resource.data.isPublic == true;

      allow create: if isOrganizer()
        && request.resource.data.ownerUid == request.auth.uid;

      allow update: if isOrganizer()
        && resource.data.ownerUid == request.auth.uid;

      allow delete: if isOrganizer()
        && resource.data.ownerUid == request.auth.uid;

      // ── registrations subcollection ──────────────────────────────────────
      match /registrations/{regId} {
        allow read: if isSignedIn() && (
          resource.data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid
        );

        allow create: if isParticipant()
          && request.resource.data.userId == request.auth.uid;

        allow update: if isOrganizer()
          && get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;

        allow delete: if false;
      }

      // ── teams subcollection ─────────────────────────────────────────────
      match /teams/{teamId} {
        allow read: if isSignedIn();

        allow create: if isParticipant();

        allow update: if isSignedIn() && (
          resource.data.captainId == request.auth.uid ||
          get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid
        );

        allow delete: if isOrganizer()
          && get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;

        // ── team members ────────────────────────────────────────────────
        match /members/{memberId} {
          allow read: if isSignedIn();
          allow create: if isParticipant();
          allow update: if isSignedIn() && (
            resource.data.userId == request.auth.uid ||
            get(/databases/$(database)/documents/events/$(eventId)/teams/$(teamId)).data.captainId == request.auth.uid
          );
          allow delete: if isSignedIn() && (
            resource.data.userId == request.auth.uid ||
            get(/databases/$(database)/documents/events/$(eventId)/teams/$(teamId)).data.captainId == request.auth.uid
          );
        }
      }

      // ── submissions subcollection ───────────────────────────────────────
      match /submissions/{subId} {
        allow read: if isSignedIn();

        allow create: if isParticipant()
          && request.resource.data.submitterId == request.auth.uid;

        allow update: if isSignedIn() && (
          resource.data.submitterId == request.auth.uid ||
          get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid
        );

        allow delete: if false;
      }

      // ── scores subcollection ────────────────────────────────────────────
      // Judges can write their own scores. Judges CANNOT read other judges' scores.
      // Organizers can read all scores.
      match /scores/{scoreId} {
        allow read: if isSignedIn() && (
          resource.data.judgeId == request.auth.uid ||
          get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid
        );

        allow create: if (isJudge() || isOrganizer())
          && request.resource.data.judgeId == request.auth.uid;

        allow update: if (isJudge() || isOrganizer())
          && resource.data.judgeId == request.auth.uid;

        allow delete: if false;
      }

      // ── announcements subcollection ─────────────────────────────────────
      match /announcements/{annId} {
        allow read: if isSignedIn();
        allow create: if isOrganizer()
          && get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;
        allow update: if isOrganizer()
          && get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;
        allow delete: if isOrganizer()
          && get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;
      }

      // ── workshops subcollection ─────────────────────────────────────────
      match /workshops/{workshopId} {
        allow read: if isSignedIn();
        allow create: if isOrganizer()
          && get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;
        allow update: if isSignedIn();
        allow delete: if isOrganizer()
          && get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;
      }
    }

    // ── hackathons collection (legacy, mirrored from events) ─────────────────
    match /hackathons/{hackathonId} {
      allow read: if isSignedIn() || resource.data.isPublic == true;
      allow create: if isOrganizer();
      allow update: if isOrganizer() && resource.data.organizerId == request.auth.uid;
      allow delete: if isOrganizer() && resource.data.organizerId == request.auth.uid;

      // Legacy subcollections (same rules as events)
      match /{subcollection}/{docId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if false;
      }

      match /{subcollection}/{docId}/{subSubcollection}/{subDocId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
      }
    }

    // ── sessions collection ───────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (
        (isOrganizer() && resource.data.ownerUid == request.auth.uid) ||
        (isParticipant() && resource.data.status == 'active')
      );
      allow create: if isOrganizer()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOrganizer()
        && resource.data.ownerUid == request.auth.uid;
      allow delete: if isOrganizer()
        && resource.data.ownerUid == request.auth.uid;
    }

    // ── attendance_records collection ─────────────────────────────────────────
    match /attendance_records/{recordId} {
      allow read: if isSignedIn();
      allow create: if isParticipant()
        && request.resource.data.participantUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── hackathons collection ────────────────────────────────────────────────
    // Providers (organizers) can CRUD their own hackathons.
    // Public hackathons are readable by any signed-in user.
    match /hackathons/{hackathonId} {

      // Organizers can read their own hackathons (any status).
      // Any signed-in user can read public hackathons.
      allow read: if isSignedIn() && (
        resource.data.organizerId == request.auth.uid ||
        resource.data.isPublic == true
      );

      // Only Providers can create hackathons.
      allow create: if isProvider()
        && request.resource.data.organizerId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.status in ['draft', 'published', 'active', 'judging', 'completed', 'archived'];

      // Only the owning organizer can update their hackathon.
      allow update: if isProvider()
        && resource.data.organizerId == request.auth.uid
        && request.resource.data.organizerId == request.auth.uid;

      // Only the owning organizer can delete their hackathon.
      allow delete: if isProvider()
        && resource.data.organizerId == request.auth.uid;
    }

    // ── registrations collection (top-level) ─────────────────────────────────
    // Participants register for hackathons. Organizers manage registrations.
    match /registrations/{registrationId} {

      // Organizers can read registrations for their hackathons.
      // Participants can read their own registrations.
      allow read: if isSignedIn() && (
        (isProvider() && get(/databases/$(database)/documents/hackathons/$(resource.data.hackathonId)).data.organizerId == request.auth.uid) ||
        (resource.data.participantUid == request.auth.uid)
      );

      // Participants can create a registration.
      allow create: if isParticipant()
        && request.resource.data.participantUid == request.auth.uid
        && request.resource.data.hackathonId is string
        && request.resource.data.status in ['pending', 'approved', 'rejected', 'waitlisted'];

      // Organizers can update registration status (approve/reject).
      // Participants can update their own registration details.
      allow update: if isSignedIn() && (
        (isProvider() && get(/databases/$(database)/documents/hackathons/$(resource.data.hackathonId)).data.organizerId == request.auth.uid) ||
        (isParticipant() && resource.data.participantUid == request.auth.uid)
      );

      allow delete: if false;
    }

    // ── teams collection (top-level) ─────────────────────────────────────────
    // Teams participate in hackathons.
    match /teams/{teamId} {

      // Organizers and team members can read the team.
      allow read: if isSignedIn() && (
        (isProvider() && get(/databases/$(database)/documents/hackathons/$(resource.data.hackathonId)).data.organizerId == request.auth.uid) ||
        (request.auth.uid in resource.data.memberUids)
      );

      // Any signed-in user can create a team.
      allow create: if isSignedIn()
        && request.resource.data.hackathonId is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.auth.uid in request.resource.data.memberUids;

      // Team members and organizers can update.
      allow update: if isSignedIn() && (
        (isProvider() && get(/databases/$(database)/documents/hackathons/$(resource.data.hackathonId)).data.organizerId == request.auth.uid) ||
        (request.auth.uid in resource.data.memberUids)
      );

      allow delete: if isProvider()
        && get(/databases/$(database)/documents/hackathons/$(resource.data.hackathonId)).data.organizerId == request.auth.uid;
    }

    // ── submissions collection (top-level) ───────────────────────────────────
    // Teams submit projects for judging.
    match /submissions/{submissionId} {

      // Organizers, judges, and submitting team members can read.
      allow read: if isSignedIn() && (
        (isProvider() && get(/databases/$(database)/documents/hackathons/$(resource.data.hackathonId)).data.organizerId == request.auth.uid) ||
        (request.auth.uid in get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.memberUids)
      );

      // Team members can create a submission.
      allow create: if isSignedIn()
        && request.resource.data.hackathonId is string
        && request.resource.data.teamId is string;

      // Team members or organizer can update.
      allow update: if isSignedIn() && (
        (isProvider() && get(/databases/$(database)/documents/hackathons/$(resource.data.hackathonId)).data.organizerId == request.auth.uid) ||
        (request.auth.uid in get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.memberUids)
      );

      allow delete: if false;
    }

    // ── scores collection (top-level) ────────────────────────────────────────
    // Judges score submissions. Organizers can read all scores.
    match /scores/{scoreId} {

      // Organizers and the scoring judge can read.
      allow read: if isSignedIn() && (
        (isProvider() && get(/databases/$(database)/documents/hackathons/$(resource.data.hackathonId)).data.organizerId == request.auth.uid) ||
        resource.data.judgeUid == request.auth.uid
      );

      // Judges (Providers) can create scores.
      allow create: if isProvider()
        && request.resource.data.judgeUid == request.auth.uid
        && request.resource.data.hackathonId is string
        && request.resource.data.submissionId is string;

      // Judges can update their own scores.
      allow update: if isProvider()
        && resource.data.judgeUid == request.auth.uid;

      allow delete: if false;
    }
  }
}
