{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vite-client",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:client"],
      "port": 5173
    },
    {
      "name": "express-server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "server/index.js"],
      "port": 5001
    },
    {
      "name": "firebase-emulators",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["firebase", "emulators:start", "--only", "functions"],
      "port": 5000
    }
  ]
}
